# Copie este archivo:
#   cp webapp/.env.example .env
# Edite .env en la RAÍZ del repo (career-ops/.env) O en webapp/.env
# Después REINICIE el servidor (Ctrl+C y npm run webapp) para que cargue la clave.
#
# NO suba .env a git. NO pegue la clave en chats.

OPENAI_API_KEY=
# Opcional: por defecto gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
# Opcional: compatible con OpenAI (p. ej. proxy)
# OPENAI_BASE_URL=
